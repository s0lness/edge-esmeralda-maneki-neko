{
  "name": "maneki",
  "version": "0.1.0",
  "private": true,
  "description": "maneki - a kindness game for Edge Esmeralda: personal agents nudge their humans into tiny acts of kindness, matched by EdgeOS co-presence and balanced by a private ledger.",
  "type": "module",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "sync:skill": "node -e \"require('fs').copyFileSync('SKILL.md','skills/maneki/SKILL.md')\""
  },
  "dependencies": {
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  }
}
